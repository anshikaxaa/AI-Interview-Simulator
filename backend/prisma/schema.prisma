// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum InterviewBlueprintStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum BlueprintFailureCode {
  AI_PROVIDER_ERROR
  AI_TIMEOUT
  AI_RATE_LIMITED
  EMPTY_AI_RESPONSE
  INVALID_AI_OUTPUT
  UNKNOWN
}

enum InterviewSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String?
  provider       AuthProvider @default(EMAIL)
  profilePicture String?

  resumes             Resume[]
  jobDescriptions     JobDescription[]
  interviewBlueprints InterviewBlueprint[]
  interviewSessions   InterviewSession[]

  failureCode   BlueprintFailureCode?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id String @id @default(cuid())

  title            String
  originalFileName String
  filePath         String
  mimeType         String
  fileSize         Int
  parsedText       String

  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewBlueprints InterviewBlueprint[]

  failureCode   BlueprintFailureCode?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model JobDescription {
  id               String  @id @default(cuid())
  title            String
  companyName      String?
  originalFileName String
  filePath         String
  mimeType         String
  fileSize         Int
  parsedText       String

  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewBlueprints InterviewBlueprint[]

  failureCode   BlueprintFailureCode?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterviewBlueprint {
  id String @id @default(cuid())

  status             InterviewBlueprintStatus @default(PENDING)
  blueprintData      Json?
  providerResponseId String?

  modelName     String?
  modelVersion  String?
  promptVersion String?

  promptTokenCount Int?
  outputTokenCount Int?
  totalTokenCount  Int?

  generationStartedAt   DateTime?
  generationCompletedAt DateTime?

  userId           String
  resumeId         String
  jobDescriptionId String

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume            Resume             @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription    JobDescription     @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]

  failureCode   BlueprintFailureCode?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([resumeId])
  @@index([jobDescriptionId])
  @@index([userId, status])
}

model InterviewSession {
  id String @id @default(cuid())

  status InterviewSessionStatus @default(IN_PROGRESS)

  currentQuestionIndex Int @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  userId      String
  blueprintId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  blueprint InterviewBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([blueprintId])
  @@index([status])
}
